# Template for infra/local-wiki/.env — copy to `.env` and fill in, then:
#   chmod 600 infra/local-wiki/.env
#
# NOTE: nothing in local dev reads this file. It exists only as the documented
# place to keep the prod FTP credentials used for the MANUAL FileZilla uploads
# in the deploy-skin / deploy-localsettings skills (CLAUDE.md §7). No script
# reads them — they're here so you have one place to find them.
#
# (The optional page downloader, download_pages_from_prod.py, takes its target
# URL from the MACCABIPEDIA_WEB_URL shell env var — default www.maccabipedia.co.il
# — not from this file.)
MACCABIPEDIA_FTP_HOST=ftp.example.com
MACCABIPEDIA_FTP_USER=changeme
MACCABIPEDIA_FTP_PASS=changeme
MACCABIPEDIA_FTP_REMOTE_ROOT=/public_html
